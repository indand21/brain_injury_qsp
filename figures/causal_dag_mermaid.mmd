%%{init: {
  "theme": "base",
  "themeVariables": {
    "fontSize": "14px",
    "fontFamily": "Arial",
    "primaryColor": "#4A90D9",
    "primaryTextColor": "#fff",
    "lineColor": "#555",
    "primaryBorderColor": "#333"
  },
  "flowchart": {
    "curve": "basis",
    "nodeSpacing": 30,
    "rankSpacing": 60,
    "padding": 12
  }
}}%%

flowchart LR

  %% ========== LAYER 0: PRE-INJURY ==========
  subgraph L0["<b>L0: Pre-Injury</b>"]
    direction TB
    AGE["Age<br/>N(55, 18)"]
    SEX["Sex<br/>Binom(0.60)"]
    EDU["Education<br/>N(12, 3)"]
    MARITAL["Marital Status"]
    EMP["Employment"]
    PSYCH["Prior Psych Hx<br/>Binom(0.18)"]
    BRAIN_INJ["Prior Brain Injury<br/>Binom(0.08)"]
    HTN["Hypertension"]
    DM["Diabetes"]
    CVD["CVD"]
    ANTICOAG["Anticoagulation"]
    SMOKE["Smoking<br/>Binom(0.35)"]
    ALCOHOL["Alcohol Misuse<br/>Binom(0.15)"]
  end

  %% ========== LAYER 1: SEVERITY ==========
  subgraph L1["<b>L1: Injury Severity</b>"]
    direction TB
    DIAG["Diagnosis<br/>TBI/SAH/Stroke/ICH"]
    GCS["GCS Admission<br/>3-15"]
    APACHE["APACHE II<br/>5-45"]
  end

  %% ========== LAYER 2: ACUTE CARE ==========
  subgraph L2["<b>L2: Acute Care / ICU</b>"]
    direction TB
    ICU_LOS["ICU LOS<br/>LogN"]
    MECH_VENT["Mech Ventilation<br/>days"]
    ICP_MON["ICP Monitoring"]
    ICP_MEAN["ICP Mean<br/>N(12, 4)"]
    MOBIL["Early Mobilisation<br/>Binom(0.35)"]
    DELIRIUM["Delirium<br/>logistic"]
    ICDSC["ICDSC Score"]
    ANX_ICU["ICU Anxiety<br/>N(5, 3)"]
    SURGERY["Surgery"]
    DVT["DVT"]
    PNEUM["Pneumonia"]
    UTI["UTI"]
  end

  %% ========== LAYER 3a: LATENT ==========
  subgraph L3a["<b>L3a: Latent / Trajectory</b>"]
    direction TB
    LATENT["Latent Severity<br/>Score"]
    TRAJ["Trajectory Class<br/>4 classes"]
  end

  %% ========== LAYER 3b: QSP ==========
  subgraph L3b["<b>L3b: QSP-ODE Features</b>"]
    direction TB
    QSP["Mechanistic Features<br/>21 variables"]
  end

  %% ========== LAYER 4: OUTCOMES ==========
  subgraph L4["<b>L4: 12-Month Outcomes</b>"]
    direction TB
    GOSE["GOSE / FIM / Barthel<br/>mRS / DRS"]
    COG["Cog Composite<br/>MoCA"]
    HADS_A["HADS-Anxiety<br/>GAD-7"]
    HADS_D["HADS-Depression<br/>PHQ-9"]
    PCL5["PCL-5<br/>PTSD"]
    QOL["SF-36 / QOLIBRI<br/>MPAI-4"]
    RTW["Return to Work<br/>Social Participation"]
    MORT["Mortality<br/>12-month"]
  end

  %% ========================================
  %%  EDGES: L0 → L1
  %% ========================================
  AGE -->|"+0.15"| APACHE
  DIAG -->|"varies"| GCS
  GCS -->|"-1.2"| APACHE

  %% ========================================
  %%  EDGES: L0/L1 → L2
  %% ========================================
  GCS -->|"severity"| ICU_LOS
  GCS -->|"severity"| MECH_VENT
  GCS -->|"GCS<=8"| ICP_MON
  ICP_MON --> ICP_MEAN
  GCS -->|"+0.15 on 15-GCS"| DELIRIUM
  AGE -->|"+0.01"| DELIRIUM
  MECH_VENT -->|"+0.5 if >3d"| DELIRIUM
  MOBIL -->|"-0.4"| DELIRIUM
  PSYCH -->|"+0.3"| DELIRIUM
  DELIRIUM --> ICDSC
  PSYCH -->|"+2.0"| ANX_ICU
  DELIRIUM -->|"+0.3"| ANX_ICU
  MOBIL -->|"-0.5"| ANX_ICU
  AGE -->|"+0.02"| ANX_ICU
  DIAG -->|"varies"| SURGERY
  MECH_VENT -->|"+0.10 if >5d"| PNEUM
  MOBIL -->|"-0.04"| DVT

  %% ========================================
  %%  EDGES: → L3a (Latent Severity)
  %% ========================================
  GCS -->|"-0.15"| LATENT
  APACHE -->|"+0.08"| LATENT
  AGE -->|"+0.02"| LATENT
  EDU -->|"-0.05"| LATENT
  PSYCH -->|"+0.50"| LATENT
  BRAIN_INJ -->|"+0.30"| LATENT
  DELIRIUM -->|"+0.40"| LATENT
  MOBIL -->|"-0.30"| LATENT
  MECH_VENT -->|"+0.20 if >7d"| LATENT
  DVT -->|"+0.30"| LATENT
  PNEUM -->|"+0.20"| LATENT
  LATENT -->|"logistic shift"| TRAJ

  %% ========================================
  %%  EDGES: → L3b (QSP-ODE)
  %% ========================================
  GCS -->|"AR_index, C0"| QSP
  APACHE -->|"MAP"| QSP
  AGE -->|"rate constants"| QSP
  ICP_MEAN -->|"ICP_init"| QSP
  DELIRIUM -->|"+0.3 DAMP"| QSP
  PSYCH -->|"microglial priming"| QSP
  ALCOHOL -->|"NI priming"| QSP

  %% ========================================
  %%  EDGES: → L4 (Outcomes)
  %% ========================================

  %% Functional outcomes
  GCS -->|"+0.20"| GOSE
  AGE -->|"-0.02"| GOSE
  EDU -->|"+0.05"| GOSE
  TRAJ -->|"x1.5 traj_mod"| GOSE
  DELIRIUM -->|"-0.30"| GOSE
  MOBIL -->|"+0.20"| GOSE
  APACHE -->|"-0.015"| GOSE

  %% Cognitive outcomes
  GCS -->|"+0.06"| COG
  AGE -->|"-0.008"| COG
  EDU -->|"+0.03"| COG
  TRAJ -->|"x0.4 traj_mod"| COG
  DELIRIUM -->|"-0.4"| COG

  %% HADS-Anxiety
  ANX_ICU -->|"+0.60"| HADS_A
  PSYCH -->|"+2.5"| HADS_A
  DELIRIUM -->|"+1.5"| HADS_A
  ALCOHOL -->|"+0.5"| HADS_A
  TRAJ -->|"-2.0 x mod"| HADS_A

  %% HADS-Depression
  PSYCH -->|"+2.5"| HADS_D
  DELIRIUM -->|"+1.0"| HADS_D
  MARITAL -->|"-0.4 married"| HADS_D
  ALCOHOL -->|"+0.4"| HADS_D
  TRAJ -->|"-2.5 x mod"| HADS_D

  %% PCL-5
  HADS_A -->|"+1.5"| PCL5
  HADS_D -->|"+1.0"| PCL5
  PSYCH -->|"+3.0"| PCL5
  ALCOHOL -->|"+2.0"| PCL5

  %% QoL
  GOSE -->|"+3.0"| QOL
  HADS_A -->|"-1.5"| QOL
  HADS_D -->|"-1.5"| QOL
  COG -->|"+5.0"| QOL
  TRAJ -->|"x8 traj_mod"| QOL

  %% Return to Work / Social
  GOSE -->|"+0.3"| RTW
  HADS_D -->|"-0.1"| RTW
  COG -->|"+0.3"| RTW
  TRAJ -->|"+1.5 x mod"| RTW
  MARITAL -->|"+3.0"| RTW

  %% Mortality
  GCS -->|"+0.3 on 15-GCS"| MORT
  AGE -->|"+0.03"| MORT
  APACHE -->|"+0.02"| MORT
  DIAG -->|"+0.5 ICH"| MORT
  MOBIL -->|"-0.3"| MORT

  %% ========================================
  %%  STYLING
  %% ========================================
  classDef preinjury fill:#4A6FA5,stroke:#2C4A7C,color:#fff,stroke-width:2px
  classDef severity fill:#E74C3C,stroke:#C0392B,color:#fff,stroke-width:2px
  classDef acutecare fill:#E67E22,stroke:#D35400,color:#fff,stroke-width:2px
  classDef latent fill:#27AE60,stroke:#1E8449,color:#fff,stroke-width:2px
  classDef qsp fill:#16A085,stroke:#117A65,color:#fff,stroke-width:2px
  classDef outcomes fill:#8E44AD,stroke:#6C3483,color:#fff,stroke-width:2px
  classDef mortality fill:#7F8C8D,stroke:#566573,color:#fff,stroke-width:2px

  class AGE,SEX,EDU,MARITAL,EMP,PSYCH,BRAIN_INJ,HTN,DM,CVD,ANTICOAG,SMOKE,ALCOHOL preinjury
  class DIAG,GCS,APACHE severity
  class ICU_LOS,MECH_VENT,ICP_MON,ICP_MEAN,MOBIL,DELIRIUM,ICDSC,ANX_ICU,SURGERY,DVT,PNEUM,UTI acutecare
  class LATENT,TRAJ latent
  class QSP qsp
  class GOSE,COG,HADS_A,HADS_D,PCL5,QOL,RTW outcomes
  class MORT mortality

  %% Subgraph styling
  style L0 fill:#D6E4F0,stroke:#4A6FA5,stroke-width:3px,color:#2C4A7C
  style L1 fill:#FADBD8,stroke:#E74C3C,stroke-width:3px,color:#C0392B
  style L2 fill:#FDEBD0,stroke:#E67E22,stroke-width:3px,color:#D35400
  style L3a fill:#D5F5E3,stroke:#27AE60,stroke-width:3px,color:#1E8449
  style L3b fill:#D1F2EB,stroke:#16A085,stroke-width:3px,color:#117A65
  style L4 fill:#E8DAEF,stroke:#8E44AD,stroke-width:3px,color:#6C3483
